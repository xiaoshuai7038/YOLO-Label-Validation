{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/missing_result.schema.json",
  "title": "MissingResult",
  "type": "object",
  "required": [
    "missing_id",
    "image_id",
    "source_ann_id",
    "class_id",
    "class_name",
    "proposed_bbox_xyxy",
    "detector_confidence",
    "decision_hint",
    "reason",
    "reason_code",
    "metric_kind"
  ],
  "properties": {
    "missing_id": {
      "type": "string"
    },
    "image_id": {
      "type": "string"
    },
    "source_ann_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "class_id": {
      "type": "integer",
      "minimum": 0
    },
    "class_name": {
      "type": "string"
    },
    "proposed_bbox_xyxy": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 4,
      "maxItems": 4
    },
    "detector_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "decision_hint": {
      "type": "string",
      "enum": [
        "add"
      ]
    },
    "reason": {
      "type": "string"
    },
    "reason_code": {
      "type": "string"
    },
    "metric_kind": {
      "type": "string",
      "enum": [
        "measured",
        "proxy",
        "pending"
      ]
    }
  },
  "additionalProperties": false
}
