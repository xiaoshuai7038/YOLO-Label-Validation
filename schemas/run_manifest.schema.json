{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/run_manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "required": [
    "run_id",
    "dataset_version",
    "class_map_version",
    "source_formats",
    "prelabel_source",
    "normalization_version",
    "primary_model_version",
    "secondary_detector_version",
    "vlm_version",
    "rules_version",
    "thresholds_version",
    "created_at",
    "artifacts",
    "input_sources",
    "record_counts"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "dataset_version": {
      "type": "string"
    },
    "class_map_version": {
      "type": "string"
    },
    "source_formats": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "prelabel_source": {
      "type": "string"
    },
    "normalization_version": {
      "type": "string"
    },
    "primary_model_version": {
      "type": "string"
    },
    "secondary_detector_version": {
      "type": "string"
    },
    "vlm_version": {
      "type": "string"
    },
    "rules_version": {
      "type": "string"
    },
    "thresholds_version": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "input_sources": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "record_counts": {
      "type": "object",
      "required": [
        "annotations",
        "images",
        "classes"
      ],
      "properties": {
        "annotations": {
          "type": "integer",
          "minimum": 0
        },
        "images": {
          "type": "integer",
          "minimum": 0
        },
        "classes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "runtime_context": {
      "type": "object",
      "properties": {
        "runtime_config_version": {
          "type": "string"
        },
        "runtime_config_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "defaults_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "thresholds_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "vlm": {
          "type": "object"
        },
        "detector": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
