{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/decision_result.schema.json",
  "title": "DecisionResult",
  "type": "object",
  "required": [
    "decision_id",
    "review_scope",
    "image_id",
    "ann_id",
    "source_ann_id",
    "class_id",
    "class_name",
    "action",
    "status",
    "reason",
    "reason_codes",
    "confidence",
    "metric_kind",
    "new_class_name",
    "new_bbox_xyxy",
    "evidence"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "review_scope": {
      "type": "string",
      "enum": [
        "annotation",
        "image"
      ]
    },
    "image_id": {
      "type": "string"
    },
    "ann_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_ann_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "class_id": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "class_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "keep",
        "relabel",
        "refine",
        "delete",
        "add",
        "manual_review"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "auto",
        "manual_review",
        "blocked"
      ]
    },
    "reason": {
      "type": "string"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "metric_kind": {
      "type": "string",
      "enum": [
        "measured",
        "proxy",
        "pending"
      ]
    },
    "new_class_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "new_bbox_xyxy": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "number"
      },
      "minItems": 4,
      "maxItems": 4
    },
    "evidence": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
