{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/review_candidate.schema.json",
  "title": "ReviewCandidate",
  "type": "object",
  "required": [
    "image_id",
    "image_score",
    "candidate_annotations",
    "image_level_candidate"
  ],
  "properties": {
    "image_id": {
      "type": "string"
    },
    "image_score": {
      "type": "number"
    },
    "candidate_annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ann_id",
          "review_scope",
          "risk_tags",
          "risk_score",
          "reason_codes"
        ],
        "properties": {
          "ann_id": {
            "type": "string"
          },
          "review_scope": {
            "type": "string",
            "enum": [
              "annotation"
            ]
          },
          "risk_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_score": {
            "type": "number"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "image_level_candidate": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "review_scope",
        "risk_tags",
        "risk_score",
        "reason_codes"
      ],
      "properties": {
        "review_scope": {
          "type": "string",
          "enum": [
            "image"
          ]
        },
        "risk_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_score": {
          "type": "number"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
