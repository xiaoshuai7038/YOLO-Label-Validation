{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/vlm_review.schema.json",
  "title": "VLMReview",
  "type": "object",
  "required": [
    "image_id",
    "ann_id",
    "decision",
    "class_ok",
    "box_ok",
    "need_refine_box",
    "need_add_missing",
    "missing_candidates",
    "reason",
    "confidence"
  ],
  "properties": {
    "image_id": {
      "type": "string"
    },
    "ann_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "keep",
        "relabel",
        "refine",
        "delete",
        "add_missing",
        "uncertain"
      ]
    },
    "class_ok": {
      "type": "boolean"
    },
    "box_ok": {
      "type": "boolean"
    },
    "new_class_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "need_refine_box": {
      "type": "boolean"
    },
    "need_add_missing": {
      "type": "boolean"
    },
    "missing_candidates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "reason": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "additionalProperties": false
}
