{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/vlm_review.schema.json",
  "title": "VLMReview",
  "type": "object",
  "required": [
    "request_id",
    "review_scope",
    "image_id",
    "ann_id",
    "decision",
    "class_ok",
    "box_ok",
    "need_refine_box",
    "need_add_missing",
    "missing_candidates",
    "reason",
    "reason_code",
    "confidence",
    "metric_kind"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "review_scope": {
      "type": "string",
      "enum": [
        "annotation",
        "image"
      ]
    },
    "image_id": {
      "type": "string"
    },
    "ann_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "keep",
        "relabel",
        "refine",
        "delete",
        "add_missing",
        "uncertain"
      ]
    },
    "class_ok": {
      "type": "boolean"
    },
    "box_ok": {
      "type": "boolean"
    },
    "new_class_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "need_refine_box": {
      "type": "boolean"
    },
    "need_add_missing": {
      "type": "boolean"
    },
    "missing_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "class_id",
          "class_name",
          "bbox_xyxy",
          "confidence",
          "reason",
          "reason_code"
        ],
        "properties": {
          "class_id": {
            "type": "integer",
            "minimum": 0
          },
          "class_name": {
            "type": "string"
          },
          "bbox_xyxy": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "reason": {
            "type": "string"
          },
          "reason_code": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "reason": {
      "type": "string"
    },
    "reason_code": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "metric_kind": {
      "type": "string",
      "enum": [
        "measured",
        "proxy",
        "pending"
      ]
    }
  },
  "additionalProperties": false
}
