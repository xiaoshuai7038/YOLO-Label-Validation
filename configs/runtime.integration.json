{
  "version": "runtime_integration_v1",
  "defaults_file": "configs/defaults.json",
  "thresholds_file": "configs/thresholds.example.yaml",
  "vlm": {
    "mode": "live",
    "provider": "openai_compatible",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "endpoint_path": "/chat/completions",
    "api_key_env": "DASHSCOPE_API_KEY",
    "model": "qwen3-vl-plus",
    "timeout_seconds": 60,
    "max_retries": 1,
    "temperature": 0.0,
    "response_format": "json_object",
    "max_tokens": 512,
    "image_transport": "data_url",
    "system_prompt": "You validate one fixed-class 2D detection annotation at a time. Return exactly one JSON object matching the requested schema. Do not add markdown fences or extra prose."
  },
  "detector": {
    "mode": "live",
    "family": "ultralytics",
    "weights_path": "artifacts/models/yolo11n.pt",
    "device": "cpu",
    "confidence_threshold": 0.25,
    "iou_threshold": 0.45,
    "max_det": 100,
    "refine_match_iou": 0.1,
    "missing_match_iou": 0.1
  }
}
